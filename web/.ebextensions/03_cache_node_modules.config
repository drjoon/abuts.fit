files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/49_cache_node_modules.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -euo pipefail
      
      echo "[cache] Checking node_modules cache..."
      
      CACHE_DIR="/var/cache/abuts-fit/node_modules"
      STAGING_DIR="/var/app/staging"
      
      # backend 디렉토리 찾기
      CANDIDATES=(
        "$STAGING_DIR/backend"
        "$STAGING_DIR/web/backend"
      )
      
      TARGET=""
      for c in "${CANDIDATES[@]}"; do
        if [ -d "$c" ]; then
          TARGET="$c"
          break
        fi
      done
      
      if [ -z "$TARGET" ]; then
        echo "[cache] Backend directory not found, skipping cache"
        exit 0
      fi
      
      echo "[cache] Backend directory: $TARGET"
      
      # package-lock.json 해시 계산
      if [ -f "$TARGET/package-lock.json" ]; then
        CURRENT_HASH=$(md5sum "$TARGET/package-lock.json" | cut -d' ' -f1)
        echo "[cache] Current package-lock.json hash: $CURRENT_HASH"
        
        # 캐시 디렉토리 생성
        mkdir -p "$CACHE_DIR"
        
        # 캐시된 해시 확인
        if [ -f "$CACHE_DIR/package-lock.hash" ]; then
          CACHED_HASH=$(cat "$CACHE_DIR/package-lock.hash")
          echo "[cache] Cached package-lock.json hash: $CACHED_HASH"
          
          if [ "$CURRENT_HASH" = "$CACHED_HASH" ] && [ -d "$CACHE_DIR/node_modules" ]; then
            echo "[cache] Cache hit! Restoring node_modules from cache..."
            
            # 기존 node_modules 제거
            rm -rf "$TARGET/node_modules"
            
            # 캐시에서 복원 (심볼릭 링크 대신 복사 사용)
            cp -a "$CACHE_DIR/node_modules" "$TARGET/node_modules"
            
            echo "[cache] node_modules restored from cache ($(du -sh $TARGET/node_modules | cut -f1))"
            
            # predeploy 훅에서 npm ci 스킵하도록 마커 파일 생성
            touch "$TARGET/.npm-cache-restored"
            
            exit 0
          else
            echo "[cache] Cache miss (hash mismatch or cache not found)"
          fi
        else
          echo "[cache] No cached hash found"
        fi
      else
        echo "[cache] package-lock.json not found, skipping cache"
      fi
      
      echo "[cache] Will install dependencies normally"
      exit 0

  "/opt/elasticbeanstalk/hooks/appdeploy/post/99_update_node_modules_cache.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -euo pipefail
      
      echo "[cache] Updating node_modules cache..."
      
      CACHE_DIR="/var/cache/abuts-fit/node_modules"
      CURRENT_DIR="/var/app/current"
      
      # backend 디렉토리 찾기
      CANDIDATES=(
        "$CURRENT_DIR/backend"
        "$CURRENT_DIR/web/backend"
      )
      
      TARGET=""
      for c in "${CANDIDATES[@]}"; do
        if [ -d "$c" ]; then
          TARGET="$c"
          break
        fi
      done
      
      if [ -z "$TARGET" ]; then
        echo "[cache] Backend directory not found, skipping cache update"
        exit 0
      fi
      
      echo "[cache] Backend directory: $TARGET"
      
      # node_modules가 존재하고 package-lock.json이 있으면 캐시 업데이트
      if [ -d "$TARGET/node_modules" ] && [ -f "$TARGET/package-lock.json" ]; then
        CURRENT_HASH=$(md5sum "$TARGET/package-lock.json" | cut -d' ' -f1)
        echo "[cache] Caching node_modules (hash: $CURRENT_HASH)..."
        
        # 캐시 디렉토리 생성
        mkdir -p "$CACHE_DIR"
        
        # 기존 캐시 제거
        rm -rf "$CACHE_DIR/node_modules"
        
        # 새 캐시 복사
        cp -a "$TARGET/node_modules" "$CACHE_DIR/node_modules"
        
        # 해시 저장
        echo "$CURRENT_HASH" > "$CACHE_DIR/package-lock.hash"
        
        echo "[cache] node_modules cached successfully ($(du -sh $CACHE_DIR/node_modules | cut -f1))"
      else
        echo "[cache] node_modules or package-lock.json not found, skipping cache update"
      fi
      
      exit 0
