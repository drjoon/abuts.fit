{
  "name": "abuts-fit-backend",
  "version": "1.0.0",
  "description": "Backend for abuts.fit - Dental implant abutment service",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env ENV_FILE=local.env nodemon server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "db:reset": "cross-env ENV_FILE=local.env node scripts/db/reset.js",
    "db:backfill": "cross-env ENV_FILE=local.env node scripts/db/backfill-business-type.js",
    "db:seed-account": "cross-env ENV_FILE=local.env node scripts/db/seed-account.js",
    "db:reset-password": "cross-env ENV_FILE=local.env node scripts/db/reset-password.js",
    "db:seed-data": "cross-env ENV_FILE=local.env node scripts/db/seed-data.js",
    "db:recomputeAnchor": "cross-env ENV_FILE=local.env node scripts/db/recomputeAnchor.js",
    "db:seed-branding": "cross-env ENV_FILE=local.env node scripts/db/seed-branding.js",
    "db:implant-preset": "cross-env ENV_FILE=local.env node scripts/db/implant-preset.js",
    "db:seed-prc": "cross-env ENV_FILE=local.env node scripts/db/seed-prc-mappings.js",
    "db:migrate-payout-rates": "cross-env ENV_FILE=local.env node scripts/db/migrate-payout-rates.js",
    "db:migrate-remake-monthly-free-rule": "cross-env ENV_FILE=local.env node scripts/db/migrate-remake-monthly-free-rule.js",
    "db:fix-mailbox-anchor-mismatch": "cross-env ENV_FILE=local.env node scripts/db/fix-request-mailbox-anchor-mismatch.js",
    "db:fix-mailbox-shipping-integrity": "cross-env ENV_FILE=local.env node scripts/db/fix-mailbox-shipping-integrity.js",
    "db:check-pricing-ssot": "cross-env ENV_FILE=local.env node scripts/db/check-pricing-ssot-consistency.js --strict",
    "db:check-pricing-ssot:ci": "node scripts/db/check-pricing-ssot-consistency.js --strict --no-write",
    "worker:monthly-referral-snapshot": "cross-env ENV_FILE=local.env node jobs/dailyReferralSnapshotWorker.js",
    "worker:daily-admin-salesman-credits-overview-snapshot": "cross-env ENV_FILE=local.env node jobs/dailyAdminSalesmanCreditsOverviewSnapshotWorker.js"
  },
  "keywords": [
    "dental",
    "implant",
    "abutment",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.859.0",
    "@aws-sdk/client-sesv2": "^3.859.0",
    "@aws-sdk/s3-request-presigner": "^3.859.0",
    "@google/generative-ai": "^0.24.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "popbill": "^1.62.0",
    "sftp-upload": "^1.0.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "@napi-rs/canvas": "^0.1.58",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "cross-env": "^10.0.0",
    "jest": "^30.0.5",
    "supertest": "^7.1.4"
  }
}
